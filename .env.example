# Controller
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=orchestrator
CONTROLLER_LOG_LEVEL=INFO
CONTROLLER_HEALTH_CHECK_TIMEOUT_SECONDS=2
CONTROLLER_HEARTBEAT_TIMEOUT_SECONDS=30
CONTROLLER_RECONCILIATION_INTERVAL_SECONDS=15
CONTROLLER_AGENT_DEPLOY_TIMEOUT_SECONDS=60
CONTROLLER_AGENT_COMMAND_TIMEOUT_SECONDS=15
CONTROLLER_AGENT_READ_TIMEOUT_SECONDS=5
CONTROLLER_MAX_RESTART_ATTEMPTS=2
CONTROLLER_COOLDOWN_INTERVALS_AFTER_RECOVERY=1
CONTROLLER_EVENT_LOG_MAX_ITEMS=500

# Agents
AGENT_LOG_LEVEL=INFO
AGENT_TELEMETRY_INTERVAL_SECONDS=5
AGENT_HEALTH_CHECK_INTERVAL_SECONDS=10
AGENT_HEALTH_CHECK_TIMEOUT_SECONDS=2
AGENT_HEALTH_CHECK_RETRIES=3

# Entry point
NGINX_HOST_PORT=18080
SAMPLE_APP_HOST_PORT=9000
